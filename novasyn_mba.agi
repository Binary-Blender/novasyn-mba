## NovaSyn MBA — Portfolio OS for Solo Founders
## Built on Agicore 4G Dev Stack
## Author: Christopher Bender / NovaSyn (MIT License, 2026)
## Community: https://www.skool.com/tao-team-ai-outreach-4986
##
## This file is the source of truth for the entire application.
## The Agicore compiler generates: SQL migrations, Rust commands,
## TypeScript types, Zustand store slices, and React components from this DSL.
##
## All Agicore primitives fully implemented — no outstanding TODOs.
##   RULE, SKILL, WORKFLOW, EVENT, ROUTER, COMPILER, STAGES, kanban VIEW

## ---------------------------------------------------------------------------
## APP
## ---------------------------------------------------------------------------

APP novasyn_mba {
  TITLE  "NovaSyn MBA"
  WINDOW 1400x900 frameless
  DB     novasyn_mba.db
  THEME  dark
}

## ---------------------------------------------------------------------------
## AI_SERVICE
## ---------------------------------------------------------------------------

AI_SERVICE {
  PROVIDERS  anthropic, openai
  KEYS_FILE  "%APPDATA%/NovaSyn/api-keys.json"
  DEFAULT    anthropic
  STREAMING  true
  MODELS {
    anthropic  "claude-sonnet-4-6"            DEFAULT
    openai     "gpt-4o"                      DEFAULT
  }
}

## ---------------------------------------------------------------------------
## ROUTER — Model-Tier Selection by Task Complexity
## ---------------------------------------------------------------------------

ROUTER advisor_router {
  DESCRIPTION "Routes MBA advisor tasks to the appropriate model tier based on complexity and scope"

  TIER 1 fast {
    haiku: anthropic "claude-haiku-4-5-20251001" {
      STRENGTHS   analysis, general
      COST        0.1
      CONTEXT     200000
      DEFAULT
    }
  }

  TIER 2 standard {
    sonnet: anthropic "claude-sonnet-4-6" {
      STRENGTHS   analysis, research, strategy, advisory
      COST        0.3
      CONTEXT     200000
      DEFAULT
    }
    gpt4o: openai "gpt-4o" {
      STRENGTHS   analysis, general, advisory
      COST        0.25
      CONTEXT     128000
    }
  }

  TIER 3 premium {
    opus: anthropic "claude-opus-4-7" {
      STRENGTHS   research, synthesis, strategy
      COST        1.5
      CONTEXT     200000
    }
  }

  TASK_TYPES   analysis, research, synthesis, strategy, advisory, general
  MOSH_PIT     2
  CALIBRATION  true
}

## ---------------------------------------------------------------------------
## PREFERENCES
## ---------------------------------------------------------------------------

PREFERENCE default_model {
  KEY     "default_model"
  DEFAULT "claude-sonnet-4-5"
  TYPE    string
}

PREFERENCE theme {
  KEY     "theme"
  DEFAULT "dark"
  TYPE    string
}

PREFERENCE weekly_review_reminder {
  KEY     "weekly_review_reminder_enabled"
  DEFAULT "true"
  TYPE    bool
}

PREFERENCE ceo_time_target_hours {
  KEY     "ceo_time_target_hours"
  DEFAULT "20"
  TYPE    number
}

## ---------------------------------------------------------------------------
## ENTITIES
## ---------------------------------------------------------------------------

ENTITY Business {
  FIELDS {
    name              TEXT     REQUIRED
    tagline           TEXT
    description       TEXT
    stage             TEXT     DEFAULT "Idea"
    category          TEXT
    market_niche      TEXT
    business_model    TEXT
    revenue_target    REAL     DEFAULT 0
    launch_date       DATE
    exit_date         DATE
    notes             TEXT
  }
  HAS_MANY StrategicPosition
  HAS_MANY OperationsAudit
  HAS_MANY DollarAudit
  HAS_MANY FinancialSnapshot
  HAS_MANY MarketingAsset
  HAS_MANY SalesContact
  HAS_MANY ContentPipelineItem
  HAS_MANY AIStackDecision
  HAS_MANY WeeklyReview
  TIMESTAMPS
  CRUD
  ORDER name ASC
}

## ---------------------------------------------------------------------------
## STAGE MACHINE — Business Lifecycle Gating
## ---------------------------------------------------------------------------

STAGES Business.stage {
  TRANSITION "Idea" -> "Validated" {
    REQUIRE StrategicPosition.value_proposition IS NOT NULL
    REQUIRE StrategicPosition.target_market IS NOT NULL
    REQUIRE SalesContact COUNT >= 1
  }
  TRANSITION "Validated" -> "Building" {
    REQUIRE SalesContact.notes IS NOT NULL
  }
  TRANSITION "Building" -> "Active" {
    MATCH any
    REQUIRE FinancialSnapshot.revenue > 0
    REQUIRE SalesContact COUNT >= 3 WHERE stage = "closed_won"
  }
  TRANSITION "Active" -> "Scaling" {
    REQUIRE FinancialSnapshot COUNT >= 2
    REQUIRE OperationsAudit.overall_score < 20
  }
}

ENTITY StrategicPosition {
  FIELDS {
    business_id         INTEGER  REQUIRED
    target_market       TEXT
    value_proposition   TEXT
    primary_moat        TEXT     DEFAULT "reputation"
    competitors         TEXT
    unfair_advantages   TEXT
    moat_score          INTEGER  DEFAULT 5
  }
  BELONGS_TO Business
  TIMESTAMPS
  CRUD
  ORDER business_id ASC
}

ENTITY OperationsAudit {
  FIELDS {
    business_id              INTEGER  REQUIRED
    knowledge_bottleneck     INTEGER  DEFAULT 3
    quality_bottleneck       INTEGER  DEFAULT 3
    coordination_bottleneck  INTEGER  DEFAULT 3
    communication_bottleneck INTEGER  DEFAULT 3
    creative_bottleneck      INTEGER  DEFAULT 3
    decision_bottleneck      INTEGER  DEFAULT 3
    overall_score            INTEGER  DEFAULT 18
    audit_date               DATE
  }
  BELONGS_TO Business
  TIMESTAMPS
  CRUD
  ORDER audit_date DESC
}

ENTITY DollarAudit {
  FIELDS {
    business_id      INTEGER  REQUIRED
    activity_name    TEXT     REQUIRED
    tier             TEXT     DEFAULT "twenty"
    hours_per_week   REAL     DEFAULT 0
    ai_transferable  INTEGER  DEFAULT 0
    transfer_status  TEXT     DEFAULT "not_started"
    notes            TEXT
  }
  BELONGS_TO Business
  TIMESTAMPS
  CRUD
  ORDER tier ASC, activity_name ASC
}

ENTITY FinancialSnapshot {
  FIELDS {
    business_id        INTEGER  REQUIRED
    period             TEXT     REQUIRED
    revenue            REAL     DEFAULT 0
    cac                REAL     DEFAULT 0
    ltv                REAL     DEFAULT 0
    ltv_cac_ratio      REAL     DEFAULT 0
    gross_margin_pct   REAL     DEFAULT 0
    mrr                REAL     DEFAULT 0
    cash_runway_months REAL     DEFAULT 0
    recorded_at        DATETIME
  }
  BELONGS_TO Business
  TIMESTAMPS
  CRUD
  ORDER recorded_at DESC
}

ENTITY MarketingAsset {
  FIELDS {
    business_id              INTEGER  REQUIRED
    asset_type               TEXT     DEFAULT "content"
    title                    TEXT     REQUIRED
    url                      TEXT
    platform                 TEXT
    published_at             DATE
    authority_stage_impact   TEXT
  }
  BELONGS_TO Business
  TIMESTAMPS
  CRUD
  ORDER published_at DESC
}

ENTITY SalesContact {
  FIELDS {
    business_id      INTEGER  REQUIRED
    name             TEXT     REQUIRED
    company          TEXT
    stage            TEXT     DEFAULT "prospect"
    ltv_potential    REAL     DEFAULT 0
    source           TEXT     DEFAULT "inbound"
    next_action      TEXT
    next_action_date DATE
    notes            TEXT
  }
  BELONGS_TO Business
  TIMESTAMPS
  CRUD
  ORDER next_action_date ASC
}

ENTITY ContentPipelineItem {
  FIELDS {
    business_id              INTEGER  REQUIRED
    idea                     TEXT     REQUIRED
    status                   TEXT     DEFAULT "idea"
    platform                 TEXT
    published_at             DATE
    inbound_leads_generated  INTEGER  DEFAULT 0
  }
  BELONGS_TO Business
  TIMESTAMPS
  CRUD
  ORDER status ASC, created_at DESC
}

ENTITY AIStackDecision {
  FIELDS {
    business_id         INTEGER  REQUIRED
    capability          TEXT     REQUIRED
    decision            TEXT     DEFAULT "buy"
    tool_or_approach    TEXT
    cost_per_month      REAL     DEFAULT 0
    is_core_capability  INTEGER  DEFAULT 0
    review_date         DATE
  }
  BELONGS_TO Business
  TIMESTAMPS
  CRUD
  ORDER is_core_capability DESC, capability ASC
}

## BoardMember is portfolio-level (no business_id foreign key)
ENTITY BoardMember {
  FIELDS {
    name              TEXT  REQUIRED
    expertise_domain  TEXT
    relationship_type TEXT  DEFAULT "mentor"
    last_consulted    DATE
    notes             TEXT
  }
  TIMESTAMPS
  CRUD
  ORDER expertise_domain ASC, name ASC
}

## PortfolioSynergy references two businesses
ENTITY PortfolioSynergy {
  FIELDS {
    business_a_id    INTEGER  REQUIRED
    business_b_id    INTEGER  REQUIRED
    synergy_type     TEXT     DEFAULT "audience"
    description      TEXT
    potential_value  TEXT
    status           TEXT     DEFAULT "identified"
  }
  BELONGS_TO Business
  TIMESTAMPS
  CRUD
  ORDER status ASC, created_at DESC
}

ENTITY WeeklyReview {
  FIELDS {
    business_id       INTEGER
    week_of           DATE     REQUIRED
    accomplishments   TEXT
    learnings         TEXT
    next_week_focus   TEXT
    energy_level      INTEGER  DEFAULT 3
    ceo_time_hours    REAL     DEFAULT 0
  }
  BELONGS_TO Business
  TIMESTAMPS
  CRUD
  ORDER week_of DESC
}

## ---------------------------------------------------------------------------
## AI ACTIONS — DISCIPLINE ADVISORS
## ---------------------------------------------------------------------------

ACTION strategy_advisor {
  AI
  INPUT {
    business_id       INTEGER  REQUIRED
    business_name     TEXT     REQUIRED
    target_market     TEXT
    value_proposition TEXT
    primary_moat      TEXT
    competitors       TEXT
    unfair_advantages TEXT
    moat_score        INTEGER
  }
  OUTPUT {
    moat_assessment        TEXT
    market_risks           TEXT
    recommended_next_move  TEXT
    question_to_ask        TEXT
    full_briefing          TEXT
  }
  PROMPT """
You are the Strategy Advisor in the NovaSyn MBA system, a portfolio OS for solo founders built on frameworks from "The One-Person Enterprise."

You are reviewing the strategic position of: {{business_name}}

STRATEGIC POSITION DATA:
- Target Market: {{target_market}}
- Value Proposition: {{value_proposition}}
- Primary Moat: {{primary_moat}} (options: reputation, system, network, content)
- Competitors: {{competitors}}
- Unfair Advantages: {{unfair_advantages}}
- Self-Assessed Moat Score: {{moat_score}}/10

FRAMEWORK CONTEXT:
The four compounding moats a solo founder can build are:
1. Reputation — trust built through consistent delivery and public expertise over time
2. System — a proprietary methodology, process, or framework that produces better results than alternatives
3. Network — relationships, community, and referral infrastructure that compounds with each new connection
4. Content — a body of work (writing, video, courses, tools) that attracts and qualifies buyers without the founder's active involvement

The Compounding Operator principle: every action should build an asset, not just complete an activity. A one-time client engagement is an activity. A case study from that engagement is an asset.

Sovereign Intelligence: you surface analysis, flag risks, and offer options. The founder decides. Never prescribe a single path as the only answer.

YOUR TASK:
1. Assess the strength and coherence of the current moat strategy. Is the stated primary moat actually present in the competitive advantages described? Does the value proposition differentiate, or is it generic?
2. Identify the top 2-3 market risks given the competitive landscape and target market. Be specific — not "competition is a risk" but "three direct competitors offer similar positioning, which means price pressure is likely without a stronger system moat."
3. Recommend the single highest-leverage next move to strengthen the primary moat. This should be something the founder can begin this week.
4. Pose the one strategic question the founder is probably not asking but should be.

Return your analysis in the four OUTPUT fields plus a full_briefing that synthesizes all four into a coherent strategic memo the founder can act on.
"""
}

ACTION operations_advisor {
  AI
  INPUT {
    business_id              INTEGER  REQUIRED
    business_name            TEXT     REQUIRED
    knowledge_bottleneck     INTEGER
    quality_bottleneck       INTEGER
    coordination_bottleneck  INTEGER
    communication_bottleneck INTEGER
    creative_bottleneck      INTEGER
    decision_bottleneck      INTEGER
    overall_score            INTEGER
    dollar_audit_summary     TEXT
  }
  OUTPUT {
    highest_leverage_bottleneck  TEXT
    bottleneck_fix_recommendation TEXT
    dollar_ratio_analysis        TEXT
    top_transfer_candidates      TEXT
    full_briefing                TEXT
  }
  PROMPT """
You are the Operations Advisor in the NovaSyn MBA system for solo founders.

You are reviewing the operational health of: {{business_name}}

OPERATIONS AUDIT (scores 1-5, higher = worse bottleneck):
- Knowledge Bottleneck: {{knowledge_bottleneck}}/5 (Am I the only one who knows how this works?)
- Quality Bottleneck: {{quality_bottleneck}}/5 (Does everything need my approval before it goes out?)
- Coordination Bottleneck: {{coordination_bottleneck}}/5 (Do people wait on me to coordinate between functions?)
- Communication Bottleneck: {{communication_bottleneck}}/5 (Am I the only voice of the business?)
- Creative Bottleneck: {{creative_bottleneck}}/5 (Does all creative work require my involvement?)
- Decision Bottleneck: {{decision_bottleneck}}/5 (Can nothing be decided without me?)
- Overall Score: {{overall_score}}/30 (6=fully systemized, 30=fully bottlenecked)

$20/$200 AUDIT SUMMARY:
{{dollar_audit_summary}}

FRAMEWORK CONTEXT:
The $20/$200 Audit: every task the founder performs is either $20/hr execution (scheduling, formatting, research, transcription, data entry, social posting, inbox triage) or $200/hr judgment (client diagnosis, strategic positioning, offer design, relationship management, creative direction). The goal is to transfer $20 tasks to AI or systems, freeing capacity for $200 work.

The self-running business ideal: a business that can generate revenue for 2 weeks without the founder's active involvement. The six bottleneck scores measure how far the current business is from this ideal.

The Delegation Ladder: (1) I do it, (2) I do it with documentation, (3) AI/system does it with my oversight, (4) AI/system does it autonomously. Every $20 task should be climbing this ladder.

YOUR TASK:
1. Identify the single highest-scoring bottleneck. Explain specifically why this bottleneck is the most costly for a solo founder and what the second-order effects are if it remains unaddressed.
2. Give a specific, actionable recommendation to address that bottleneck using AI or a system. Be concrete — name a specific type of tool, template, or process.
3. Analyze the $20/$200 ratio. What percentage of the founder's work hours are currently at each tier? What is the target, and what is the gap?
4. List the top 3 $20-tier tasks from the audit that are AI-transferable and not yet transferred. Explain why these are the highest-value transfers.

Return findings in the OUTPUT fields plus a full_briefing memo.
"""
}

ACTION finance_advisor {
  AI
  INPUT {
    business_id        INTEGER  REQUIRED
    business_name      TEXT     REQUIRED
    period             TEXT
    revenue            REAL
    cac                REAL
    ltv                REAL
    ltv_cac_ratio      REAL
    gross_margin_pct   REAL
    mrr                REAL
    cash_runway_months REAL
  }
  OUTPUT {
    unit_economics_diagnosis  TEXT
    red_flag_metrics          TEXT
    pricing_recommendation    TEXT
    runway_assessment         TEXT
    full_briefing             TEXT
  }
  PROMPT """
You are the Finance Advisor in the NovaSyn MBA system for solo founders.

You are reviewing the unit economics of: {{business_name}}

FINANCIAL SNAPSHOT — Period: {{period}}
- Revenue: ${{revenue}}
- Customer Acquisition Cost (CAC): ${{cac}}
- Lifetime Value (LTV): ${{ltv}}
- LTV:CAC Ratio: {{ltv_cac_ratio}} (target: >3, watch: 2-3, critical: <2)
- Gross Margin: {{gross_margin_pct}}% (target: >50% for services, >60% for digital)
- Monthly Recurring Revenue (MRR): ${{mrr}}
- Cash Runway: {{cash_runway_months}} months (target: >6 months, critical: <3 months)

FRAMEWORK CONTEXT:
Value-based pricing, never hourly. The price charged should reflect the value delivered to the client, not the time spent by the founder. A founder who charges $150/hr for work that saves the client $50,000/year is leaving 99% of the value on the table.

Key thresholds from "The One-Person Enterprise":
- LTV:CAC < 2: the acquisition model is broken — the business is paying too much to get customers who don't stay long enough
- Gross margin < 50%: the business is not scalable — too much of revenue goes to direct costs
- Cash runway < 6 months: existential risk — the 6-month runway rule is a non-negotiable operating constraint
- MRR > $10K: proof of recurring demand and a fundable, scalable model

YOUR TASK:
1. Provide a plain-language unit economics diagnosis. What do these numbers say about the health of the business model? What is working, what is not?
2. Flag every metric that is below the target thresholds. For each red flag, explain the specific risk it creates for the business.
3. If gross margin is below 50%, give a concrete pricing recommendation. What should change — the price point, the offer structure, or the delivery model?
4. Assess the cash runway. Is the business in a safe, watch, or critical position? What specific action should the founder take in the next 30 days given the runway situation?

Return findings in the OUTPUT fields plus a full_briefing memo the founder can act on this week.
"""
}

ACTION marketing_advisor {
  AI
  INPUT {
    business_id           INTEGER  REQUIRED
    business_name         TEXT     REQUIRED
    asset_summary         TEXT
    content_pipeline_summary TEXT
    total_assets          INTEGER
    published_content_count INTEGER
    total_inbound_leads   INTEGER
  }
  OUTPUT {
    authority_ladder_position TEXT
    gap_analysis              TEXT
    top_three_content_moves   TEXT
    platform_risk_assessment  TEXT
    full_briefing             TEXT
  }
  PROMPT """
You are the Marketing Advisor in the NovaSyn MBA system for solo founders.

You are reviewing the marketing position of: {{business_name}}

MARKETING ASSETS SUMMARY:
{{asset_summary}}

CONTENT PIPELINE SUMMARY:
{{content_pipeline_summary}}
- Total published pieces: {{published_content_count}}
- Total inbound leads attributed: {{total_inbound_leads}}

FRAMEWORK CONTEXT:
Authority-first marketing: the goal is to become the obvious authority in a specific niche, so that buyers come to the founder already pre-sold. This is the only marketing model that compounds over time. Paid advertising stops when the spend stops. Authority compounds.

The Authority Ladder — five stages every buyer moves through:
1. Unknown: the target market has never heard of this founder
2. Aware: they know the founder exists
3. Credible: they believe the founder knows what they are talking about
4. Authoritative: they consider the founder one of the best in the field
5. Referred: they actively send other people to the founder

Each stage requires different content moves:
- Unknown → Aware: reach content (short-form, social posts, podcast guest spots, SEO articles)
- Aware → Credible: depth content (long-form guides, case studies, frameworks with the founder's name attached)
- Credible → Authoritative: proof content (published testimonials, documented results, a distinctive point of view the founder owns)
- Authoritative → Referred: community content (cohorts, events, a referral system, founder-to-founder relationships)

The content-to-client pipeline: Idea → Drafted → Reviewed → Published → Attributed Lead → Closed Client. Every piece of content is a sales asset with a measurable conversion rate.

YOUR TASK:
1. Based on the asset mix and content history, assess where this business currently sits on the authority ladder. Be specific — cite the evidence.
2. Identify the gap: what content types or platforms are missing for the next ladder stage?
3. Recommend the top 3 specific content moves the founder should make in the next 30 days to advance to the next authority stage. Be concrete — not "write more content" but "publish one 2,000-word case study documenting a client result, optimized for the search term [specific niche term]."
4. Assess platform concentration risk. Is the founder too dependent on one platform? What is the backup plan if that platform's reach drops?

Return findings in the OUTPUT fields plus a full_briefing memo.
"""
}

ACTION sales_advisor {
  AI
  INPUT {
    business_id              INTEGER  REQUIRED
    business_name            TEXT     REQUIRED
    pipeline_summary         TEXT
    stale_contacts_summary   TEXT
    referral_pct             REAL
    total_pipeline_value     REAL
  }
  OUTPUT {
    pipeline_health_score   TEXT
    stale_contact_actions   TEXT
    top_follow_up_actions   TEXT
    referral_architecture   TEXT
    full_briefing           TEXT
  }
  PROMPT """
You are the Sales Advisor in the NovaSyn MBA system for solo founders.

You are reviewing the sales pipeline of: {{business_name}}

PIPELINE SUMMARY:
{{pipeline_summary}}

STALE CONTACTS (next_action_date in the past):
{{stale_contacts_summary}}

PIPELINE METRICS:
- Referral-sourced contacts: {{referral_pct}}% (target: >50% for a healthy referral flywheel)
- Total pipeline value (LTV potential): ${{total_pipeline_value}}

FRAMEWORK CONTEXT:
Sales conversation architecture for solo founders:
1. Qualify first — before any discovery call, establish that the prospect has the problem, the budget, and the authority to decide. Time-box unqualified prospects aggressively.
2. Diagnose before prescribing — the sales conversation is a diagnostic. The founder's job is to understand the problem well enough to know whether this is the right client, not to pitch.
3. Prescribe with confidence — once the diagnosis is clear, the recommendation should be specific and direct. Wishy-washy proposals lose.

The qualification gate: any contact that has been in the "prospect" stage for more than 14 days without a qualification conversation is either not a real prospect or is being handled incorrectly. Stale prospects are a signal of a qualification problem, not a follow-up problem.

The referral flywheel: the best source of new clients is closed clients. A referral-sourced prospect arrives pre-sold, with a shorter sales cycle and lower CAC. If less than 50% of pipeline is referral-sourced, the founder needs a deliberate referral architecture — not hope.

Referral architecture components: (1) ask at the right moment (immediately after a win), (2) make it specific ("do you know another [target market descriptor] who has [specific problem]?"), (3) make it easy (a shareable one-page overview of who you help), (4) close the loop (report back on what happened with the referral).

YOUR TASK:
1. Score the pipeline health. Is the stage distribution healthy (enough prospects to feed the funnel, proposals converting at a reasonable rate)? What is the most critical pipeline problem right now?
2. For each stale contact, recommend a specific follow-up action. Rank by LTV potential. Be direct — if a contact should be removed from the pipeline, say so.
3. List the top 3 follow-up actions the founder should take this week, ranked by expected value.
4. Assess the referral architecture. Given that {{referral_pct}}% of pipeline is referral-sourced, what specific step should the founder take to improve the referral flywheel?

Return findings in the OUTPUT fields plus a full_briefing memo.
"""
}

ACTION tech_advisor {
  AI
  INPUT {
    business_id              INTEGER  REQUIRED
    business_name            TEXT     REQUIRED
    stack_summary            TEXT
    total_monthly_tool_spend REAL
    core_capability_spend    REAL
  }
  OUTPUT {
    spend_analysis              TEXT
    core_capability_risk        TEXT
    dependency_concentration    TEXT
    top_automation_opportunities TEXT
    full_briefing               TEXT
  }
  PROMPT """
You are the Technology Advisor in the NovaSyn MBA system for solo founders.

You are reviewing the tech stack decisions of: {{business_name}}

CURRENT STACK:
{{stack_summary}}

FINANCIAL SUMMARY:
- Total monthly tool spend: ${{total_monthly_tool_spend}}
- Spend on core-capability tools (is_core_capability = true): ${{core_capability_spend}}

FRAMEWORK CONTEXT:
The build/buy/automate decision matrix:
- BUILD when the capability is a source of competitive differentiation and no existing tool can replicate the advantage. Build only what is truly core.
- BUY when a good tool exists for a commodity capability. Buying a CRM is not a strategic decision; it is an operating decision.
- AUTOMATE when a task is repetitive, rule-based, and currently done manually by the founder. Automation is often the highest-ROI investment a solo founder can make.

Warning signs in a solo founder's tech stack:
1. Paying for a commodity capability (e.g. an expensive custom-built email system when Mailchimp exists)
2. Paying for a core-capability tool that could be built with a one-time investment (buying a competitive advantage)
3. Too many critical capabilities on one vendor (single point of failure)
4. Manual processes that exist only because no one has set up the automation yet

The Sovereign Intelligence frame applies to tech decisions: the founder's judgment about what to build, buy, and automate is itself $200/hr work. Defaulting to "just buy a tool" without strategic thinking is $20/hr behavior.

YOUR TASK:
1. Analyze the monthly spend. Is the total reasonable for the revenue stage? Are there obvious cuts?
2. For each core-capability tool (is_core_capability = true), assess whether the build/buy decision is correct. Is this founder paying for a competitive advantage they should own, or correctly buying a commodity?
3. Identify dependency concentration risks. Is there a single vendor or platform that would create a crisis if it disappeared or raised prices 10x?
4. List the top 3 automation opportunities — things the founder is currently doing manually that could be automated with existing tools or simple AI scripting.

Return findings in the OUTPUT fields plus a full_briefing memo.
"""
}

ACTION leadership_advisor {
  AI
  INPUT {
    business_id          INTEGER
    founder_name         TEXT
    recent_reviews       TEXT
    avg_energy_level     REAL
    avg_ceo_time_hours   REAL
    review_count         INTEGER
  }
  OUTPUT {
    energy_trend_assessment  TEXT
    ceo_time_ratio           TEXT
    pattern_identification   TEXT
    accountability_question  TEXT
    full_briefing            TEXT
  }
  PROMPT """
You are the Leadership Advisor in the NovaSyn MBA system for solo founders.

You are reviewing the leadership and self-accountability data for: {{founder_name}}

RECENT WEEKLY REVIEWS (last {{review_count}} weeks):
{{recent_reviews}}

AGGREGATE METRICS:
- Average energy level: {{avg_energy_level}}/5 (watch: <3.5, burnout risk: <3.0 for 3+ consecutive weeks)
- Average CEO-time hours per week: {{avg_ceo_time_hours}} (target: 20+ hours/week on $200/hr judgment work)

FRAMEWORK CONTEXT:
The CEO discipline: a solo founder wears many hats, but the CEO hat is the most important and most neglected. CEO time is time spent on strategy, positioning, high-value relationships, offer design, and self-development. Every hour the founder spends on $20 execution tasks is an hour not spent on the CEO role.

Energy management principle: output quality degrades before the founder notices it. A founder running at 2/5 energy for three weeks is making worse strategic decisions, having worse client conversations, and producing worse creative work — even if they believe they are functioning normally. The energy level score is not a mood tracker; it is a performance leading indicator.

The mental board of directors: a curated set of perspectives the founder actively consults when facing decisions. This might include a mentor, a peer, an author, or an archetype (e.g. "what would the version of me who has solved this problem think?"). Decisions made without consulting the board tend to be reactive; decisions made after consulting the board tend to be strategic.

Patterns in weekly reviews: recurring learnings that appear in multiple reviews but do not result in changed behavior are the most important signal. If the founder writes "I need to protect my mornings for deep work" three weeks in a row but the next_week_focus never includes a concrete mechanism to protect mornings, the review process is not working.

YOUR TASK:
1. Assess the energy trend. Is the founder recovering, stable, or declining? If the average energy level is below 3.5, flag burnout risk and recommend a specific recovery action.
2. Assess the CEO-time ratio. Is the founder spending enough time on $200/hr judgment work? What is the gap, and what specific $20 task should be transferred this week to create the space?
3. Identify the most important pattern in the recent reviews. Look for recurring themes in learnings, recurring next_week_focus items that never get resolved, and any disconnects between stated priorities and actual accomplishments.
4. Ask the one accountability question the founder should sit with this week. Make it specific and uncomfortable — not "are you taking care of yourself?" but a question that cuts to the actual pattern you observed.

Return findings in the OUTPUT fields plus a full_briefing memo.
"""
}

ACTION portfolio_synergy_detector {
  AI
  INPUT {
    founder_name       TEXT
    portfolio_summary  TEXT
    existing_synergies TEXT
  }
  OUTPUT {
    top_synergies     TEXT
    synergy_actions   TEXT
    full_briefing     TEXT
  }
  PROMPT """
You are the Portfolio Synergy Detector in the NovaSyn MBA system.

You are analyzing the full portfolio of: {{founder_name}}

PORTFOLIO SUMMARY (all active businesses with their strategic positions, content assets, and tech stacks):
{{portfolio_summary}}

EXISTING SYNERGIES ALREADY IDENTIFIED:
{{existing_synergies}}

FRAMEWORK CONTEXT:
The Compounding Operator principle: an asset that serves multiple businesses simultaneously is exponentially more valuable than an asset that serves one. A piece of content that builds authority for two businesses at once is worth twice as much as one that builds for only one. A distribution channel that sells two products simultaneously has double the leverage.

Five synergy types:
1. Audience: two businesses serve the same target customer. The audience built in one business can be leveraged by the other.
2. Tech: two businesses use the same underlying technology or infrastructure. Consolidation could reduce cost or increase capability.
3. Distribution: two businesses could share a platform, channel, or partnership.
4. Content: content produced for one business builds authority for another (shared expertise domain, shared problem territory).
5. Supplier: two businesses could negotiate with the same vendor together, or share access to the same resource.

The portfolio lens: a solo founder managing multiple businesses is in a position no corporate business unit ever occupies — they can see across all their businesses simultaneously and make decisions that optimize the whole portfolio, not just each individual business. This is a genuine competitive advantage if it is used deliberately.

YOUR TASK:
Review all businesses in the portfolio summary. Identify the top 3-5 unexploited synergies that are NOT already in the existing synergies list. For each synergy:
1. Name the two businesses involved
2. Identify the synergy type
3. Describe specifically what the synergy is — not vaguely but concretely (e.g. "The audience of [Business A] — mid-size consulting firm owners — is the exact buyer profile for [Business B]'s SaaS product")
4. Recommend a specific, actionable first step the founder can take this week to begin exploiting this synergy

Rank your synergies by estimated value (time saved, revenue potential, or moat-building impact). Return the top 3-5 only — do not list every possible connection. Focus on the ones with the clearest near-term action.

Return findings in the OUTPUT fields plus a full_briefing memo.
"""
}

## ---------------------------------------------------------------------------
## IMPL ACTIONS — DETERMINISTIC TOOLS
## ---------------------------------------------------------------------------

ACTION advance_business_stage {
  IMPL
  INPUT {
    business_id  INTEGER  REQUIRED
    new_stage    TEXT     REQUIRED
  }
  OUTPUT {
    success  INTEGER
    message  TEXT
  }
}

ACTION calculate_ltv_cac {
  IMPL
  INPUT {
    snapshot_id  INTEGER  REQUIRED
    ltv          REAL     REQUIRED
    cac          REAL     REQUIRED
  }
  OUTPUT {
    ltv_cac_ratio  REAL
    health_flag    TEXT
  }
}

ACTION export_business_report {
  IMPL
  INPUT {
    business_id  INTEGER  REQUIRED
  }
  OUTPUT {
    file_path  TEXT
    success    INTEGER
  }
}

ACTION generate_pitch_deck_outline {
  IMPL
  INPUT {
    business_id  INTEGER  REQUIRED
  }
  OUTPUT {
    file_path  TEXT
    success    INTEGER
  }
}

ACTION import_csv_contacts {
  IMPL
  INPUT {
    business_id  INTEGER  REQUIRED
    csv_path     TEXT     REQUIRED
  }
  OUTPUT {
    imported_count  INTEGER
    skipped_count   INTEGER
    error_summary   TEXT
  }
}

ACTION synthesize_first_30_days {
  AI
  INPUT {
    business_id  INTEGER  REQUIRED
  }
  OUTPUT {
    day_1_to_10    TEXT
    day_11_to_20   TEXT
    day_21_to_30   TEXT
    top_priority   TEXT
    full_plan      TEXT
  }
  PROMPT """
You have just completed a full diagnostic of a new business: strategy positioning, operations audit, and financial health review. Your task is to synthesize these findings into a concrete First 30 Days action plan.

Structure your plan into three 10-day sprints:
Days 1-10: Foundation — stop the bleeding, identify the single most critical constraint
Days 11-20: Systems — put the first key system in place to address that constraint
Days 21-30: Momentum — establish the first repeatable cycle (sales, delivery, or content)

For each sprint, provide 2-3 specific, actionable steps. Not vague advice. Specific actions this founder can take this week.

Identify the single top priority for Day 1.
"""
}

## ---------------------------------------------------------------------------
## WORKFLOW — Business Onboarding Sequence
## ---------------------------------------------------------------------------

WORKFLOW business_onboarding {
  STEP analyze_strategy {
    ACTION strategy_advisor
    ON_FAIL stop
  }
  STEP audit_operations {
    ACTION operations_advisor
    ON_FAIL skip
  }
  STEP review_financials {
    ACTION finance_advisor
    ON_FAIL skip
  }
  STEP synthesize_plan {
    ACTION synthesize_first_30_days
    ON_FAIL stop
  }
}

## ---------------------------------------------------------------------------
## SKILL — Discipline Knowledge Frameworks
## ---------------------------------------------------------------------------

SKILL finance_frameworks {
  DESCRIPTION "Core financial frameworks for evaluating business unit economics and capital efficiency"
  DOMAIN "finance"
  CONTENT "LTV:CAC Ratio: Healthy 3:1+, Warning 2:1, Critical below 2:1. Gross Margin targets: SaaS 70%+, Services 50%+. Cash Runway: Critical <3 months, Warning <6 months. MRR Growth: healthy 10%+ MoM. Break-even: Revenue = Fixed Costs / Gross Margin. Burn multiple: Net Burn / Net New ARR < 1 = efficient."
  APPLIES_TO [finance_advisor]
  KEYWORDS finance, ltv, cac, mrr, runway, gross_margin, burn_rate
  PRIORITY 8
}

SKILL strategy_frameworks {
  DESCRIPTION "Strategic positioning frameworks for competitive moat analysis and market differentiation"
  DOMAIN "strategy"
  CONTENT "Value Proposition: What do you do, for whom, better than who. Moat types: network_effect, switching_cost, cost_advantage, intangible_asset, system. Positioning: Category x Differentiator x Target. The 3 uniques: unique mechanism, unique proof, unique offer. Jobs-to-be-done: functional, social, emotional. Crossing the Chasm: focus on the beachhead."
  APPLIES_TO [strategy_advisor]
  KEYWORDS strategy, positioning, moat, value_proposition, competitive_advantage
  PRIORITY 8
}

SKILL operations_frameworks {
  DESCRIPTION "Operational bottleneck analysis and delegation frameworks for solo founders"
  DOMAIN "operations"
  CONTENT "6 Bottleneck Types: knowledge (only you know), quality (only you can judge), coordination (only you can align), communication (only you relay), creative (only you create), decision (only you decide). Dollar Audit: $20/hr tasks (AI-transferable), $200/hr tasks (founder-only). Systemization sequence: document, delegate, automate. Score 0-4 per bottleneck; total >18 = critical."
  APPLIES_TO [operations_advisor]
  KEYWORDS operations, bottleneck, delegation, systemization, dollar_audit
  PRIORITY 8
}

SKILL marketing_frameworks {
  DESCRIPTION "B2B authority marketing and content strategy frameworks for professional services"
  DOMAIN "marketing"
  CONTENT "Authority Stages: aware -> credible -> authoritative -> dominant. Content ladder: social posts -> articles -> case studies -> speaking -> media. Distribution: owned (list, site), earned (PR, referrals), paid (ads). Positioning before promotion. Specificity drives conversion: name the niche, name the problem, name the outcome."
  APPLIES_TO [marketing_advisor]
  KEYWORDS marketing, authority, content, positioning, distribution, b2b
  PRIORITY 7
}

SKILL sales_frameworks {
  DESCRIPTION "Consultative B2B sales and pipeline management frameworks"
  DOMAIN "sales"
  CONTENT "Pipeline stages: aware, engaged, qualified, proposal, negotiation, closed_won, closed_lost. LTV calculation: avg_deal_size x avg_duration x margin. CAC: total_sales_marketing_spend / new_customers. Qualification: BANT (Budget, Authority, Need, Timing). Follow-up cadence: 24h, 3d, 7d, 14d. Referral triggers: at close, at first result, at 90 days."
  APPLIES_TO [sales_advisor]
  KEYWORDS sales, pipeline, ltv, cac, qualification, referral
  PRIORITY 7
}

SKILL leadership_frameworks {
  DESCRIPTION "Founder energy management and leadership development frameworks"
  DOMAIN "leadership"
  CONTENT "Energy management: physical (sleep, exercise, nutrition), mental (focus blocks, deep work), emotional (relationships, meaning). CEO time audit: strategic planning, business development, team/systems. Energy score 1-5: 1-2 = burnout risk, 3 = baseline, 4-5 = high performance. Weekly review cadence: accomplishments, learnings, next week focus. Vision-to-action: 3yr, 1yr, 90-day, weekly."
  APPLIES_TO [leadership_advisor]
  KEYWORDS leadership, energy, ceo_time, focus, weekly_review
  PRIORITY 7
}

SKILL tech_decision_frameworks {
  DESCRIPTION "Build/buy/automate decision frameworks and AI stack evaluation criteria for solo founders"
  DOMAIN "technology"
  CONTENT "Build/Buy/Automate matrix: BUILD when the capability is a source of competitive differentiation (core). BUY when a good-enough commodity tool exists. AUTOMATE when the task is repetitive, rule-based, and currently manual. Stack principles: model-agnostic (no single-vendor lock-in), portable (your intelligence outlives any platform), composable (tools connect), minimal (every tool added costs cognitive overhead). Tool evaluation: does it solve a real bottleneck? Does it integrate? Is intelligence portable if it disappears? Switching cost? Cognitive overhead? Review cadence: quarterly."
  APPLIES_TO [tech_advisor]
  KEYWORDS technology, build_buy_automate, stack, tools, automation, vendor_risk
  PRIORITY 7
}

SKILL portfolio_intelligence_frameworks {
  DESCRIPTION "Cross-portfolio synergy detection and compounding operator principles"
  DOMAIN "portfolio"
  CONTENT "Five synergy types: (1) Audience — same buyer across businesses; (2) Tech — shared infrastructure or tooling; (3) Distribution — shared channel, platform, or partnership; (4) Content — expertise built in one business that builds authority for another; (5) Supplier — shared vendor relationships or bulk negotiation. Compounding Operator principle: an asset serving multiple businesses simultaneously is exponentially more valuable than one serving only one. Portfolio lens advantage: a solo founder can optimize the whole portfolio simultaneously — something no corporate business unit can do. Synergy identification cadence: quarterly scan across all active businesses."
  APPLIES_TO [portfolio_synergy_detector]
  KEYWORDS portfolio, synergy, compounding, audience, distribution, content_leverage
  PRIORITY 6
}

## ---------------------------------------------------------------------------
## RULE — Automated Business Health Checks
## ---------------------------------------------------------------------------

RULE ltv_cac_critical {
  IF FinancialSnapshot.ltv_cac_ratio < 2
  THEN FLAG "finance_risk"
  SEVERITY critical
  PRIORITY 10
}

RULE cash_runway_danger {
  IF FinancialSnapshot.cash_runway_months < 3
  THEN FLAG "existential_risk"
  SEVERITY critical
  PRIORITY 10
}

RULE operations_bottlenecked {
  IF OperationsAudit.overall_score > 24
  THEN FLAG "operations_critical"
  SEVERITY high
  PRIORITY 8
}

RULE low_energy_warning {
  IF WeeklyReview.energy_level < 3
  THEN FLAG "founder_burnout_risk"
  SEVERITY high
  PRIORITY 8
}

RULE missed_revenue_target {
  IF FinancialSnapshot.gross_margin_pct < 50
  THEN FLAG "margin_pressure"
  SEVERITY medium
  PRIORITY 5
}

## ---------------------------------------------------------------------------
## EVENT — Time-Based and Data-Driven Triggers
## ---------------------------------------------------------------------------

EVENT weekly_review_reminder {
  DESCRIPTION "Monday morning reminder to complete the weekly business review"
  SCHEDULE "0 9 * * 1"
  SUBSCRIBERS [leadership_advisor]
}

EVENT monthly_financial_snapshot {
  DESCRIPTION "First day of month prompt to record financial snapshot and review unit economics"
  SCHEDULE "0 8 1 * *"
  SUBSCRIBERS [finance_advisor]
}

EVENT quarterly_strategy_review {
  DESCRIPTION "Quarterly reminder to reassess strategic position, moat, and competitors"
  SCHEDULE "0 8 1 1,4,7,10 *"
  SUBSCRIBERS [strategy_advisor]
}

## ---------------------------------------------------------------------------
## COMPILER — Semantic Transformation Pipelines
## ---------------------------------------------------------------------------

COMPILER reviews_to_action_plan {
  DESCRIPTION  "Distill recent weekly reviews into a prioritized action plan"
  FROM         WeeklyReview
  TO           WeeklyReview
  EXTRACT      accomplishments, learnings, next_week_focus, energy_level, ceo_time_hours
  ENRICH {
    INFER       behavioral_patterns
    DETECT      recurring_blockers
    SUGGEST     ceo_time_improvements
    GENERATE    weekly_action_plan
  }
  AI           "Analyze these weekly review entries. Identify patterns the founder repeats week-to-week without resolving. Produce a concrete prioritized action plan for the coming week — not a summary of what was already written, but a synthesis of what the pattern suggests should change."
  VALIDATE     true
}

COMPILER advisor_outputs_to_priorities {
  DESCRIPTION  "Compile multiple discipline advisor briefings into a ranked priority list"
  FROM         Business
  TO           Business
  EXTRACT      name, stage, market_niche, business_model, notes
  ENRICH {
    INFER       cross_discipline_dependencies
    DETECT      conflicting_priorities
    SUGGEST     sequencing
    GENERATE    ranked_30_day_priorities
  }
  AI           "You have received briefings from multiple MBA discipline advisors (strategy, operations, finance, marketing, sales, technology, leadership). Your job is to synthesize these into a single ranked priority list. Identify where advisors agree (highest confidence items), where they conflict (requires founder judgment), and produce a sequenced 30-day action plan that respects cross-discipline dependencies."
  VALIDATE     true
}

COMPILER financial_data_to_report {
  DESCRIPTION  "Transform FinancialSnapshot records into a structured business health report"
  FROM         FinancialSnapshot
  TO           FinancialSnapshot
  EXTRACT      revenue, cac, ltv, ltv_cac_ratio, gross_margin_pct, mrr, cash_runway_months
  ENRICH {
    INFER       trend_direction
    DETECT      threshold_violations
    SUGGEST     corrective_actions
    GENERATE    executive_summary
  }
  AI           "Analyze these financial snapshots over time. Calculate trends (improving, stable, declining) for each metric. Flag any metric that has crossed a critical threshold ($20/$200 framework: LTV:CAC < 2, gross margin < 50%, runway < 6 months). Generate an executive summary a solo founder can act on in 15 minutes."
  VALIDATE     true
}

COMPILER business_data_to_pitch {
  DESCRIPTION  "Transform structured business entity data into a pitch narrative outline"
  FROM         Business
  TO           Business
  EXTRACT      name, tagline, market_niche, business_model, revenue_target, notes
  ENRICH {
    INFER       investor_appeal
    SUGGEST     narrative_structure
    GENERATE    one_pager_outline
    PRESERVE    founder_voice
  }
  AI           "Using the structured business data provided, generate a pitch narrative outline. Follow the structure: Problem → Solution → Why Now → Why Us → Business Model → Traction → Ask. Preserve the founder's original language for the value proposition and unfair advantages — do not sanitize into generic pitch-speak."
  VALIDATE     false
}

## ---------------------------------------------------------------------------
## VIEWS
## ---------------------------------------------------------------------------

VIEW portfolio_dashboard {
  ENTITY Business
  LAYOUT dashboard
  ACTIONS [advance_business_stage, portfolio_synergy_detector]
}

VIEW business_cards {
  ENTITY Business
  LAYOUT cards
  ACTIONS [advance_business_stage]
}

VIEW business_detail {
  ENTITY Business
  LAYOUT detail
  ACTIONS [
    strategy_advisor
    operations_advisor
    finance_advisor
    marketing_advisor
    sales_advisor
    tech_advisor
    leadership_advisor
    export_business_report
    generate_pitch_deck_outline
    advance_business_stage
  ]
}

VIEW dollar_audit_tool {
  ENTITY DollarAudit
  LAYOUT list
  ACTIONS []
}

VIEW unit_economics_dashboard {
  ENTITY FinancialSnapshot
  LAYOUT list
  ACTIONS [calculate_ltv_cac]
}

VIEW content_pipeline {
  ENTITY ContentPipelineItem
  LAYOUT kanban
  GROUP_BY status
  ACTIONS []
}

VIEW sales_pipeline {
  ENTITY SalesContact
  LAYOUT kanban
  GROUP_BY stage
  ACTIONS [sales_advisor]
}

VIEW weekly_review_form {
  ENTITY WeeklyReview
  LAYOUT detail
  ACTIONS [leadership_advisor]
}

VIEW synergy_board {
  ENTITY PortfolioSynergy
  LAYOUT list
  ACTIONS [portfolio_synergy_detector]
}

VIEW board_members {
  ENTITY BoardMember
  LAYOUT list
  ACTIONS []
}

